# ============================================
# Supply Chain Tracking System - Environment Variables
# ============================================
# Copy this file to .env and fill in your values

# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Connection
# Replace with your MongoDB Atlas URI or local URI
MONGODB_URI=mongodb://localhost:27017/supplychain

# JWT Secret (use a strong random string in production)
JWT_SECRET=supplychain_stellar_jwt_secret_2024_change_this

# Stellar Network (use TESTNET for development)
STELLAR_NETWORK=TESTNET
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
